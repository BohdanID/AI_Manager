            price.VAT = 0;
            price.TreatmentUUID = treatment.UUID;
            price.TreatmentID = treatment.ID;

            iPraxDbContext.Add(price);
            iPraxDbContext.SaveChanges();

            //Mahngebuehr - 2
            Treatment treatment2 = new Treatment();
            treatment2.DateCreated = DateTime.Now;
