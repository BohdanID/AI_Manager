@page "/General/CreatePraxis"

@inject AuthenticationStateProvider authenticationStateProvider;
@inject IDbContextFactory<TriggerFriendlyIpraxDbContext> iPraxContextFactory;
@inject IDbContextFactory<TriggerFriendlyIpraxKundenportalDbContext> iPraxKundenportalContextFactory;

@inject IJSRuntime jsRuntime;
@inject NavigationManager navigationManager;
@inject ILogger<CreatePraxis> logger;
@inject IConfiguration config;

@using static SharedData.Enums;
@using static Webinator.Data.Tables;
@using static Webinator.Data.ValidationModels;
@using SharedData.BillingSql;
@using static Utils.Utils;
@using CollmexUtils
@using KeeperUtils
@using KeeperSecurity.Configuration
@using Microsoft.Extensions.Logging
@using System.IO

<div class="unified-margin-top-main-view" style="height: 100%; display: flex; justify-content: center;">
    @if (userClaimsPrincipal!.IsInRole("Vertrieb") || userClaimsPrincipal.IsInRole("Admin"))
    {
        if (show_form || (praxisCreationFailure && !partialCreationFailure))
        {
            <EditForm style="height: 100%;" EditContext="@createPraxisContext">
                <DataAnnotationsValidator />
                <div class="w3-card-4 iprax-card-border-radius" style="margin-top: 0px; margin-bottom: 100px; display: table; padding: 10px; float: none; position: relative; margin-left: auto; margin-right: auto; width: 80%; max-width: 1050px;">
                    <div style="white-space: nowrap; width: 100%; display: flex; align-items: center; border-bottom: 1px solid lightgray; padding-bottom: 20px;">
                        <div style="font-size: 30px; width: fit-content;">
                            Neue Praxis
                        </div>
                        <div style="white-space: nowrap; width: 100%; justify-content: end; display: flex;">
                            <button style="bottom: 13px; right: 13px;" disabled="@isPraxisCreationRunning" @onclick="(() => navigationManager.NavigateTo(navigationManager.BaseUri))" type="button" class="button-abort">Abbrechen</button>
                            @if (creationButtonDisabled || (partialCreationFailure && !praxisCreationFailure))
                            {
                                <button style="opacity: 0.5; cursor:not-allowed;" disabled="disabled" class="button-accept">Praxis erstellen</button>
                            }
                            else
                            {
                                <button style="bottom: 13px; right: 13px;" id="submitButton" disabled="@isPraxisCreationRunning" type="button" class="button-accept" @onclick="CheckFaultyEntriesOrShowConfirmation">Praxis erstellen</button>
                            }
                        </div>
                    </div>
                    <div style="margin-top: 8px;">
                        <table style="width: 100%; min-width: 1100px;">
                            <tbody>
                                <tr>
                                    <td style="vertical-align: top;">
                                        <table class="praxis-creation-table">
                                            <tbody>
                                                <tr>
                                                    <td class="praxis-creation-table-headline" colspan="2">
                                                        Kontaktdaten
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" type="text" @bind-Value="createPraxisModel!.InputPraxisname" placeholder="Praxis-Firmenname" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" type="text" @bind-Value="createPraxisModel!.Department" placeholder="Praxis-Abteilung" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="padding-right: 10px">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" type="text" @bind-Value="createPraxisModel!.InputFirstName" placeholder="Vorname" autocomplete="off" />
                                                    </td>
                                                    <td style="padding-left: 10px">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" type="text" @bind-Value="createPraxisModel!.InputLastName" placeholder="Nachname" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" type="text" @bind-Value="createPraxisModel!.InputAddress" placeholder="Straße" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="padding-right: 10px">
                                                        <InputText class="iprax-account-input form-select-praxis-creation praxis-creation-plz text-align-left" type="text" @bind-Value="createPraxisModel!.InputPlz" placeholder="PLZ" autocomplete="off" />
                                                    </td>
                                                    <td style="padding-left: 10px">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" type="text" @bind-Value="createPraxisModel!.InputCity" placeholder="Ort" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">
                                                        <InputSelect class="form-select form-select-praxis-creation iprax-account-input" @bind-Value="createPraxisModel!.InputRegion">
                                                            <option value="" disabled selected hidden>Bundesland</option>
                                                            @foreach (var region in regionTable!)
                                                            {
                                                                <option value="@region.ID">@region.Description</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" style="width:100%;" type="text" @bind-Value="createPraxisModel!.InputPhone" placeholder="Telefonnummer" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" style="width:100%;" type="text" @bind-Value="createPraxisModel!.InputMobile" placeholder="Handynummer" autocomplete="off" />
                                                    </td>
                                                </tr>

                                                <tr>
                                                    <td colspan="2">
                                                        <InputText class="iprax-account-input form-select-praxis-creation text-align-left" style="width:100%;" type="text" @bind-Value="createPraxisModel!.InputMail" placeholder="E-Mail-Adresse" autocomplete="off" />
                                                    </td>
                                                </tr>
                                            <tr>
                                                <td colspan="2">
                                                    <InputText class="iprax-account-input form-select-praxis-creation text-align-left" style="width:100%;" type="text" @bind-Value="createPraxisModel!.InputIban" placeholder="IBAN" autocomplete="off"/>
                                                    @if (!createPraxisContext!.IsValid(() => createPraxisModel!.InputIban!))
                                                    {
                                                    <div class="popup" style="position: relative"> 
                                                        <div class="popuptext" style="position: absolute; box-shadow: 0px 0px 3px 1px Rgba(0.2,0.2,0.2,0.3); border-radius: 6px; top: -35px; background-color: white; left: 452px; height: fit-content; z-index: 1; width: fit-content;">
                                                            <div style=" font-size: 15px; white-space: nowrap; margin: 5px 0; text-align: left; padding-left: 8px; padding-right: 8px;">
                                                                <ValidationMessage For="() => createPraxisModel!.InputIban" ></ValidationMessage>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    }
                                                </td>
                                            </tr>
                                                @if (userClaimsPrincipal.IsInRole("Admin"))
                                                {
                                                    <tr>
                                                        <td colspan="2">
                                                            <div style="width: 100%; display: flex; align-items: center;">
                                                                <div style="width: 70%;">
                                                                    Test-Praxis (Keine Collmex-Anbindung)
                                                                </div>
                                                                <div style="text-align: start; height: 35px; width: 30%">
                                                                    <div style="display: flex; height: 100%; align-items: center; justify-content: end;">
                                                                        <label class="switch">
                                                                            <InputCheckbox class="invisible" type="checkbox" @bind-Value="isTestPraxis" />
                                                                            <span class="slider"></span>
                                                                        </label>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td class="praxis-creation-table-headline" colspan="2" style="padding-top: 20px;">
                                                        Institutionskennzeichen
                                                    </td>
                                                </tr>

                                                <tr>
                                                    <td style="vertical-align: middle">
                                                        Physiotherapie:
                                                    </td>
                                                    <td>
                                                        <div style="display: flex; align-items: center;">
                                                            <InputNumber class="iprax-account-input form-select-praxis-creation spinners-removed" @bind-Value:get="createPraxisModel!.NumPhysio" @bind-Value:set="(e => {createPraxisModel!.NumPhysio = e > 0 ? e : 0; UpdateInstitutions(1); })" type="number" min="0" autocomplete="off" />
                                                            <div class="symbol-simple" @onclick="(() => ShowInstitutionEditDialog(1))">@symbolEdit</div>
                                                        </div>
                                                    </td>
                                                </tr>

                                                <tr>
                                                    <td style="vertical-align: middle">
                                                        Ergotherapie:
                                                    </td>
                                                    <td>
                                                        <div style="display: flex; align-items: center;">
                                                            <InputNumber class="iprax-account-input form-select-praxis-creation spinners-removed" @bind-Value:get="createPraxisModel!.NumErgo" @bind-Value:set="(e => {createPraxisModel!.NumErgo = e > 0 ? e : 0; UpdateInstitutions(2);})" type="number" min="0" autocomplete="off" />
                                                            <div class="symbol-simple" @onclick="(() => ShowInstitutionEditDialog(2))">@symbolEdit</div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="vertical-align: middle">Logopädie:</td>
                                                    <td>
                                                        <div style="display: flex; align-items: center;">
                                                            <InputNumber class="iprax-account-input form-select-praxis-creation spinners-removed" @bind-Value:get="createPraxisModel!.NumLogo" @bind-Value:set="(e => {createPraxisModel!.NumLogo = e > 0 ? e : 0; UpdateInstitutions(3);})" type="number" min="0" autocomplete="off" />
                                                            <div class="symbol-simple" @onclick="(() => ShowInstitutionEditDialog(3))">@symbolEdit</div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="vertical-align: middle">Podologie:</td>
                                                    <td>
                                                        <div style="display: flex; align-items: center;">
                                                            <InputNumber class="iprax-account-input form-select-praxis-creation spinners-removed" @bind-Value:get="createPraxisModel!.NumPodo" @bind-Value:set="(e => {createPraxisModel!.NumPodo = e > 0 ? e : 0; UpdateInstitutions(5); })" type="number" min="0" autocomplete="off" />
                                                            <div class="symbol-simple" @onclick="(() => ShowInstitutionEditDialog(5))">@symbolEdit</div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="vertical-align: middle">Heilpraktiker:</td>
                                                    <td>
                                                        <div style="display: flex; align-items: center;">
                                                            <InputNumber class="iprax-account-input form-select-praxis-creation spinners-removed" @bind-Value:get="createPraxisModel!.NumHeil" @bind-Value:set="(e => {createPraxisModel!.NumHeil = e > 0 ? e : 0; UpdateInstitutions(4); })" type="number" min="0" autocomplete="off" />
                                                            <div class="symbol-simple" @onclick="(() => ShowInstitutionEditDialog(4))">@symbolEdit</div>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                    <td style="vertical-align: top; justify-content: end; display: flex;">
                                        <table class="praxis-creation-table" style="width: 500px;">
                                            <tbody>
                                                <tr>
                                                    <td class="praxis-creation-table-headline" style="padding-bottom: 8px;" colspan="2">
                                                        Praxiseinstellungen
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="min-width: 200px;">
                                                        Spaltenanzahl:
                                                    </td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>
                                                            <label style="height:35px; margin-top: 1px; padding-top:5px;">1</label>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            <InputNumber class="iprax-account-input form-select-praxis-creation spinners-removed" type="number" @bind-Value:get="createPraxisModel!.NumTherapists" @bind-Value:set="(e => {createPraxisModel!.NumTherapists = e > 0 ? e : 1; UpdateTherapists();})" min="1" />
                                                        </td>
                                                        <td>
                                                            <div class="symbol-simple" @onclick="(() => showTherapistEditDialog = true)">
                                                                @symbolEdit
                                                            </div>
                                                        </td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Raster:
                                                    </td>
                                                    <td>
                                                        <InputSelect class="form-select form-select-praxis-creation iprax-account-input" @bind-Value="createPraxisModel!.InputFrequency">
                                                            <option value="-1" disabled selected hidden>Raster</option>
                                                            <option value="5">5</option>
                                                            <option value="10">10</option>
                                                            <option value="15">15</option>
                                                            <option value="20">20</option>
                                                            <option value="25">25</option>
                                                            <option value="30">30</option>
                                                        </InputSelect>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Abrechnung:
                                                    </td>
                                                    <td>
                                                        <InputSelect class="form-select form-select-praxis-creation iprax-account-input" @bind-Value="createPraxisModel!.CashSettingInt">
                                                            <option value="-1" disabled selected hidden>Abrechnung</option>
                                                            <option value="0">Cash Basic</option>
                                                            <option value="1">Cash Complete (srzh)</option>
                                                            <option value="2">Cash Direct</option>
                                                            <option value="5">Cash Flex (rfhm)</option>
                                                        </InputSelect>
                                                    </td>
                                                </tr>
                                                @if (createPraxisModel!.CashSettingInt == 2)
                                                {
                                                    <tr>
                                                        <td style="padding-top: 15px;">
                                                            Mtl. Kosten:
                                                        </td>
                                                        <td>
                                                            <div style="text-align: start; height: 35px;">
                                                                <InputNumber class="form-select-praxis-creation iprax-account-input spinners-removed" style=" text-align: right; width: 130px !important;" type="number" @bind-Value="createPraxisModel!.CashDirectPriceMonthly" min="0" autocomplete="off" />
                                                                <label>€</label>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                                else if (createPraxisModel!.CashSettingInt == 5)
                                                {
                                                    <tr>
                                                        <td style="padding-top: 15px;">
                                                            iPrax Cash:
                                                        </td>
                                                        <td>
                                                            <div style="text-align: start; height: 35px;">
                                                                <div style="padding-top: 10px; display: flex">
                                                                    <label class="switch">
                                                                        <InputCheckbox class="invisible" type="checkbox" @bind-Value="createPraxisModel!.isIpraxCash" @oninput="(() => CheckResetInputs())"/>
                                                                        <span class="slider"></span>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    <tr style="height: 45.5px;">
                                                        <td style="padding-top: 15px;">
                                                        </td>
                                                        <td>
                                                            <div style="text-align: start; height: 35px;"></div>
                                                        </td>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td class="praxis-creation-table-headline" colspan="2" style="white-space: nowrap; padding-top: 20px;">
                                                        Zusätzliche Funktionen
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Foto/Video:
                                                    </td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>
                                                            <label style="height:35px; margin-top: 1px; padding-top:5px;">deaktiviert</label>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            <div style="height: 35px; display: flex; align-items: center;">
                                                                <div style="width: fit-content; text-align: right; align-items: center; display: flex; justify-content: end">
                                                                    <label class="switch" style="margin-left: auto;">
                                                                        <InputCheckbox class="invisible" type="checkbox" @bind-Value="createPraxisModel!.FotoVideoActive" />
                                                                        <span class="slider"></span>
                                                                    </label>
                                                                </div>
                                                                <div style="width: 100%; text-align: right; width: 260px; display: flex; align-items: center; justify-content: end;">
                                                                    @if (createPraxisModel!.FotoVideoActive)
                                                                    {
                                                                        <label style="margin-left: 15px; width: 80px; white-space: nowrap;">Mtl. Kosten:</label>
                                                                        <InputNumber class="form-select-praxis-creation iprax-account-input form-select-praxis-creation spinners-removed" style="margin-left: 15px; width: 130px;" type="number" @bind-Value="createPraxisModel!.FotoVideoPriceStandard" min="0" autocomplete="off" />
                                                                        <label>&nbsp;€</label>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td style="height: 35px;">
                                                        Kassenbuch:
                                                    </td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>
                                                            <label style="height:35px; margin-top: 2px; padding-top:5px;">deaktiviert</label>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            <div style="height: 35px; display: flex; align-items: center;">
                                                                <div style="text-align: right; align-items: center; display: flex;" justify-content:end>
                                                                    <label class="switch" style="margin-left: auto;">
                                                                        <InputCheckbox class="invisible" type="checkbox" @bind-Value="createPraxisModel!.TseCashBookActive" />
                                                                        <span class="slider"></span>
                                                                    </label>
                                                                </div>
                                                                <div style="width: 100%; text-align: right; width: 260px; display: flex; align-items: center; justify-content: end;">
                                                                    @if (createPraxisModel!.TseCashBookActive)
                                                                    {
                                                                        <label style="margin-left: 15px; white-space: nowrap;">Mtl. Kosten:</label>
                                                                        <InputNumber class="form-select-praxis-creation iprax-account-input form-select-praxis-creation spinners-removed" style="margin-left: 15px; width: 130px;" type="number" @bind-Value="createPraxisModel!.CashBookPriceStandard" min="0" autocomplete="off" />
                                                                        <label>&nbsp;€</label>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td class="praxis-creation-table-headline" colspan="2" style="padding-top: 20px">
                                                        Lizenz und Geräte
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Lizenz:</td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>iPrax One</td>
                                                    }
                                                    else
                                                    {
                                                        <td>@Utilities.GetLicenseText(devicesWithExtras.Count())</td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td style="white-space: nowrap;">
                                                        Mtl. Kosten:
                                                    </td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>
                                                            <label style="height:35px; margin-top: 2px; padding-top:5px;">0</label>
                                                            <label>€</label>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            <InputNumber class="form-select-praxis-creation iprax-account-input spinners-removed" style="width: 130px;" type="number" @bind-Value="createPraxisModel!.IpraxMonthlyFeeSpecialPrice" min="0" autocomplete="off" />
                                                            <label>€</label>
                                                        </td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Geräte:
                                                    </td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>
                                                            <label style="height:35px; width: 340px; margin-top: 2px; padding-top:5px;">1</label>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            <div style="display: flex; align-items: center;">
                                                                <InputNumber class="form-select-praxis-creation iprax-account-input spinners-removed" type="number" @bind-Value:get="createPraxisModel!.NumDevices" @bind-Value:set="(e => {createPraxisModel!.NumDevices = e > 0 ? e : 1; UpdateDevices();})" min="1" oninvalid="setCustomValidity('Es muss mindestens 1 Gerät angelegt werden.')" oninput="setCustomValidity('')"/>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="symbol-simple" @onclick="(() => showDeviceEditDialog = true)">
                                                                @symbolEdit
                                                            </div>
                                                        </td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td class="praxis-creation-table-headline" colspan="2" style="padding-top: 20px">
                                                        Rabatt und Zahlungsinformationen
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Unterschrift (SEPA):</td>
                                                    <td>
                                                        <InputDate class="iprax-account-input form-select-praxis-creation praxis-creation-plz text-align-left" @bind-Value="createPraxisModel!.InputSignatureDateCustomer" autocomplete="off" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Zahlbar innerhalb von:</td>
                                                    <td>
                                                        <InputSelect class="form-select form-select-praxis-creation iprax-account-input" @bind-Value="createPraxisModel!.inputPaymentCondition">
                                                            <option value="@CollmexUtils.Enums.Zahlungsbedingung.Tage14OhneAbzug">14 Tage ohne Abzug</option>
                                                            <option value="@CollmexUtils.Enums.Zahlungsbedingung.Tage30OhneAbzug">30 Tage ohne Abzug</option>
                                                            <option value="@CollmexUtils.Enums.Zahlungsbedingung.Tage60OhneAbzug">60 Tage ohne Abzug</option>
                                                        </InputSelect>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Rabatt:
                                                    </td>
                                                    @if (createPraxisModel!.isIpraxCash)
                                                    {
                                                        <td>
                                                            <label style="height:35px; margin-top: 2px; padding-top:5px;">0</label>
                                                            <label>€</label>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            <InputNumber class="form-select-praxis-creation iprax-account-input form-select-praxis-creation spinners-removed" style="width: 130px; text-align: right;" min="0" @bind-Value="createPraxisModel!.Discount" />
                                                            <label>€</label>
                                                        </td>
                                                    }
                                                </tr>
                                                <tr>
                                                    <td style="white-space:nowrap;">
                                                        Vertragsbeginn:
                                                    </td>
                                                    <td style="padding-bottom: 10px;">
                                                        <div style="display: flex; justify-content: space-around;">
                                                            <InputDate class="iprax-account-input form-select-praxis-creation praxis-creation-plz text-align-left" @bind-Value="createPraxisModel!.StartOfContract" autocomplete="off" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </EditForm>
        }
        else
        {
            <div class="show_data" style="height: fit-content; padding: 20px; border-radius: 7px; box-shadow: 0 0 3px 1px rgba(0.2,0.2,0.2,0.3);">
                <div class="modal-popup-header-container">
                    <div class="modal-popup-header">Praxis erstellt</div>
                    <div class="modal-popup-btn-container" style="align-items: center;">
                        <button @onclick="(() => ForceReloadCreatePraxisWithCheck(createPraxisModel!.NewPraxisID))" style="width: 110px; min-width: unset;" class="button-accept">Fertig</button>
                    </div>
                </div>
                <hr/>
                @if (!sendSuccessful)
                {
                    <p style="color: red; font-weight: bold">Achtung E-Mail mit dem CryptionKey konnte nicht verschickt werden oder Einpflegen in Keeper fehlgeschlagen!<br/> Bitte unbedingt notieren! Fehler beim Einpflegen in Keeper: @keeperError</p>
                    <div class="w3-panel w3-pale-yellow w3-leftbar w3-border-red">
                        <p>Nach Verlassen dieser Seite ist der CryptionKey unwiderruflich verloren, falls nicht andernorts notiert!</p>
                    </div>
                    <p style="color: red">Bitte den CryptionKey sichern und das Boss-Passwort notieren!</p>
                    <p style="color: red">
                        <input id="gelesen" type="checkbox" @bind-value="@cryptionKeySavedManually"/>
                        <label for="gelesen">Ich habe den CryptionKey gesichert</label>
                    </p>
                }

                <table class="w3-table" style="width: unset; margin: 0;box-shadow: unset;">
                    @if (!sendSuccessful)
                    {
                        <tr>
                            <td class="datatable" style="padding-left: unset;">CryptionKey</td>
                            <td class="datatable">@CryptionKey</td>
                            <td class="datatable">
                                <button class="link-lookalike-button" onclick="copyTextToClipboard('@CryptionKey'); return false;">Kopieren</button>
                            </td>
                        </tr>
                    }

                    <tr>
                        <td class="datatable" style="padding-left: unset;">Zugangsdaten:</td>
                        <td></td>
                        <td class="datatable">
                            <button id="btnPDF" class="link-lookalike-button" @onclick="DownloadPdfForNewPraxis">Herunterladen</button>
                        </td>
                    </tr>
                    <tr>
                        <td class="datatable" style="padding-left: unset;">PraxisID:</td>
                        <td class="datatable">@createPraxisModel!.NewPraxisID</td>
                        <td class="datatable">
                            <button class="link-lookalike-button" onclick="copyTextToClipboard('@createPraxisModel!.NewPraxisID'); return false;">Kopieren</button>
                        </td>
                    </tr>

                    <tr>
                        <th class="datatable" style="padding-left: unset;">Boss-Passwort</th>
                        <td class="datatable">@bossPW</td>
                        <td class="datatable">
                            <button class="link-lookalike-button" onclick="copyTextToClipboard('@bossPW'); return false;">Kopieren</button>
                        </td>
                    </tr>
                </table>
            </div>
        }
    }
</div>

