                    CopyPriceListheilPraktiker = institutionInfoWithExtras.CopyPriceListHeilpraktiker, 
                    TargetDateOneTime = _oneTimeInvoiceStart, 
                    TargetDatePeriodic = _periodicInvoiceStart
                };
                
                Utilities.CreateInstitution(heilData);
            }

            foreach (InstitutionInfoWithExtras institutionInfoWithExtras in podosWithExtras)
            {
                if (descriptionNeedsInstitution)
                {
                    praxisNameKeeper += "Podo ";
                    descriptionNeedsInstitution = false;
                }
                
                CreateInstitutionData pogoData = new CreateInstitutionData
                {
                    InstitutionInfo = institutionInfoWithExtras.InstitutionInfo, 
                    PaymentCondition = createPraxisModel!.inputPaymentCondition, 
                    Type = 5, 
                    RegionId = int.Parse(createPraxisModel!.InputRegion!), 
                    User = user, 
                    PraxisId = createPraxisModel!.NewPraxisID, 
                    CustomerNo = createPraxisModel!.CustomerNo, 
                    InsertPendingBillingChange = insertPendingBillingChange, 
                    IncreaseMaxIkCount = true, 
                    DbContextFactory = iPraxContextFactory, 
                    IPraxKundenportalContextFactory = iPraxKundenportalContextFactory, 
                    CryptionKey = CryptionKey, 
                    UnsyncedPraxisSettings = unsyncedPraxisSetting, 
                    CustomPriceMaxIk = institutionInfoWithExtras.IsFirstNonHeilpraktiker ? null : institutionInfoWithExtras.Price, 
                    CustomPriceMonthly = institutionInfoWithExtras.IsFirstNonHeilpraktiker ? null : institutionInfoWithExtras.PriceMonthly, 
                    FreeIk = !institutionInfoWithExtras.IsFirstNonHeilpraktiker && institutionInfoWithExtras.IsFree, 
                    CopyPriceListheilPraktiker = false, 
                    TargetDateOneTime = _oneTimeInvoiceStart, 
                    TargetDatePeriodic = _periodicInvoiceStart
                };
                
                Utilities.CreateInstitution(pogoData);
            }
            
            int keeperPraxisID = currentServer != CurrentServer.Live ? createPraxisModel!.NewPraxisID + 100000 : createPraxisModel!.NewPraxisID;
            string nameKeeper = praxisNameKeeper + (string.IsNullOrWhiteSpace(createPraxisModel!.InputLastName) ? createPraxisModel!.InputPraxisname + " " + createPraxisModel!.Department : createPraxisModel!.InputLastName);
            
            praxisNameKeeper =  nameKeeper + ", ID " + keeperPraxisID;
        }
        catch (Exception ex)
        {
            logger.LogError(ex, ex.Message);
            partialCreationFailure = true;
            throw new Exception("Die Institutionen, Geräte, Spalten und User konnten nicht angelegt werden.");
        }
    }

    private void CreateTherapists()
    {
        try
        {
            int currentTherapistCount = 0;
            int includedTherapistCount = GetIncludedTherapistCount();

            using TriggerFriendlyIpraxDbContext iPraxDbContext = iPraxContextFactory.CreateDbContext();
            using TriggerFriendlyIpraxKundenportalDbContext iPraxKundenportalDbContext = iPraxKundenportalContextFactory.CreateDbContext();

            foreach (TherapistWithExtras therapistWithExtra in therapistsWithExtras)
            {
                therapistWithExtra.Therapist!.PraxisID = createPraxisModel!.NewPraxisID;
                therapistWithExtra.Therapist.FirstName = Cryption.EncryptString("Therapeut " + (currentTherapistCount + 1), CryptionKey!);
                therapistWithExtra.Therapist.LastName = Cryption.EncryptString("", CryptionKey!);
                therapistWithExtra.Therapist.DateSync = DateTime.Now;

                iPraxDbContext.Therapist.Add(therapistWithExtra.Therapist);
                currentTherapistCount++;
            }

            iPraxDbContext.SaveChanges();

            currentTherapistCount = 0;

            string user = authenticationStateProvider.GetAuthenticationStateAsync().Result.User.Identity!.Name!;

            if (!createPraxisModel!.isIpraxCash && !isTestPraxis)
            {
                foreach (TherapistWithExtras therapistWithExtra in therapistsWithExtras)
                {
                    iPraxKundenportalDbContext.PendingBillingChanges.Add(new PendingBillingChange()
                    {
                        SourceSoftware = Program.EVENTLOG_SOURCE,
                        SourceUser = user,
                        PraxisID = createPraxisModel!.NewPraxisID,
                        CustomerNo = createPraxisModel!.CustomerNo,
                        Price = currentTherapistCount < includedTherapistCount ? 0 : therapistWithExtra.PriceMonthly,
                        BillingUpdateEnum = Enum.GetName(BillingTypeEnum.NewColumn)!,
                        EntityUUID = therapistWithExtra.Therapist!.UUID,
                        EntityIprax = therapistWithExtra.Therapist.GetType().Name,
                        DateInvoiceStart = _periodicInvoiceStart,
                        DateCreated = DateTime.Now,
                        DateModified = DateTime.Now
                    });

                    currentTherapistCount++;
                }
            }
            iPraxKundenportalDbContext.SaveChanges();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, ex.Message);
            partialCreationFailure = true;
            throw new Exception("Die Spalten und User konnten nicht angelegt werden.");
        }
    }

    private void UpdateTherapists()
    {
        int diff = createPraxisModel!.NumTherapists - therapistsWithExtras.Count();

        decimal priceTherapist = Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.NewColumn);

        if (diff < 0 && therapistsWithExtras.Where(x => x.PriceMonthly != priceTherapist).Any())
        {
            createPraxisModel!.NumTherapists = therapistsWithExtras.Count();
            jsRuntime.InvokeVoidAsync("showCustomError", "Der Preis für eine Spalte wurde geändert, daher müssen die Spalten im Edit-Dialog gelöscht werden.");
            return;
        }

        if (diff > 0)
        {
            for (int i = 0; i < Math.Abs(diff); i++)
            {
                therapistsWithExtras.Add(new TherapistWithExtras()
                {
                    Therapist = new Therapist()
                    {
                        DateCreated = DateTime.Now,
                        UUID = Guid.NewGuid(),
                        AddressID = -1,
                        FirstName = "",
                        LastName = "",
                        UserIDModified = 999999,
                        DeviceIDModified = 999999,
                        PraxisID = createPraxisModel!.NewPraxisID,
                        DateModified = DateTime.Now,
                        ColumnID = 0,
                        ValidFrom = new DateTime(1900, 01, 01, 0, 0, 0),
                        ValidTill = new DateTime(3000, 01, 01, 0, 0, 0),
                        DateSync = DateTime.Now
                    },
                    PriceMonthly = priceTherapist
                });
            }

            SetTherapistColumnIds();
        }
        else
        {
            for (int i = 0; i < Math.Abs(diff); i++)
            {
                therapistsWithExtras.RemoveAt(therapistsWithExtras.Count() - 1);
            }
        }
    }

    private int GetIncludedTherapistCount()
    {
        return int.Max(createPraxisModel!.NumPhysio
               + createPraxisModel!.NumPodo
               + createPraxisModel!.NumErgo
               + createPraxisModel!.NumLogo 
               - GetFreeIkCount(), 1);
    }
    
    private int GetFreeIkCount()
    {
        return physiosWithExtras.Count(x => x.IsFree) +
               ergosWithExtras.Count(x => x.IsFree) +
               logosWithExtras.Count(x => x.IsFree) +
               podosWithExtras.Count(x => x.IsFree);
    }
    
    private void SetTherapistColumnIds()
    {
        for (int i = 0; i < therapistsWithExtras.Count(); i++)
        {
            therapistsWithExtras[i].Therapist!.ColumnID = i + 1;
        }
    }

