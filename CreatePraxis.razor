                iPraxKundenportalContext.PendingBillingChanges.Add(GetPendingBillingChanges(user!, Utilities.GetBillingPrice(billingPrices!, praxisLicence), praxisLicence, (int)createPraxisModel!.inputPaymentCondition, praxis.UUID, praxis.GetType().Name, _oneTimeInvoiceStart));
                iPraxKundenportalContext.PendingBillingChanges.Add(GetPendingBillingChanges(user!, createPraxisModel!.IpraxMonthlyFeeSpecialPrice, BillingTypeEnum.IPraxMonthly, -1, praxis.UUID, praxis.GetType().Name, _periodicInvoiceStart));
