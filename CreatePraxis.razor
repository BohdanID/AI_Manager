            treatment2.PraxisID = createPraxisModel!.NewPraxisID;
            treatment2.TreatmentCode = "Mahngeb. 2";
            treatment2.TreatmentGroupID = 56;
            treatment2.TreatmentTypeID = 2;
            treatment2.UserIDModified = 999999;
            treatment2.UUID = Guid.NewGuid();
            iPraxDbContext.Add(treatment2);
            iPraxDbContext.SaveChanges();

