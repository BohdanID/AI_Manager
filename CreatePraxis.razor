    private void CreateDevices(bool insertPendingBillingChange)
    {
        var user = authenticationStateProvider.GetAuthenticationStateAsync().Result.User.Identity!.Name;

        try
        {
            using TriggerFriendlyIpraxDbContext iPraxDbContext = iPraxContextFactory.CreateDbContext();

            int currentCount = 0;

            DateTime serverDateTime = iPraxDbContext.Praxis.AsNoTracking().Select(x => DateTime.Now).First();

            foreach (DeviceWithExtras deviceWithExtras in devicesWithExtras)
            {
                CreateDeviceData createDeviceData = new CreateDeviceData()
                {
                    Device = deviceWithExtras.Device,
                    User = user,
                    PraxisId = createPraxisModel!.NewPraxisID,
                    CustomerNo = createPraxisModel!.CustomerNo,
                    PaymentCondition = createPraxisModel!.inputPaymentCondition,
                    CustomPrice = currentCount < 2 ? 0m : deviceWithExtras.Price,
                    InsertBillingChange = insertPendingBillingChange,
                    UpdateUnsyncedPraxisSettings = true,
                    IPraxDbContextFactory = iPraxContextFactory,
                    IPraxKundenportalContextFactory = iPraxKundenportalContextFactory,
                    ServerDateTime = serverDateTime,
                    BillingPrices = billingPrices,
                    UnsyncedPraxisSettings = unsyncedPraxisSetting,
                    TargetDate = _oneTimeInvoiceStart
                };

                Utilities.CreateDevice(createDeviceData, config);
                currentCount++;
            }
        }
        catch (Exception ex)
        {
            partialCreationFailure = true;
            logger.LogError(ex, ex.Message);
            throw new Exception("Die Geräte, Spalten und User konnten nicht angelegt werden.");
