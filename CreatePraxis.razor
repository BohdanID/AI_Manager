    private void ShowInstitutionEditDialog(int treatmentDirectoryId)
    {
        if (treatmentDirectoryId < 1 || treatmentDirectoryId > 5)
        {
            errorMessage = $"Die TreatmentDirectoryID {treatmentDirectoryId} ist keine gültige Institution.";
            showErrorPopup = true;
            return;
        }

        currentInstitutionEditType = treatmentDirectoryId;
        currentInstitutionName = treatmentDirectoryId == 1 ? "Physiotherapie" :
            treatmentDirectoryId == 2 ? "Ergotherapie" :
            treatmentDirectoryId == 3 ? "Logopädie" :
            treatmentDirectoryId == 4 ? "Heilpraktiker" :
            "Podologie";

        currentInstitutionInfosWithExtras = GetCurrentInstititutionWithExtrasList(treatmentDirectoryId);

        showInstitutionInfoEditDialog = true;
    }

    private List<InstitutionInfoWithExtras>
        GetCurrentInstititutionWithExtrasList(int treatmentDirectoryId)
    {
        return treatmentDirectoryId == 1 ? physiosWithExtras :
            treatmentDirectoryId == 2 ? ergosWithExtras :
            treatmentDirectoryId == 3 ? logosWithExtras :
            treatmentDirectoryId == 4 ? heilsWithExtras :
            podosWithExtras;
    }

    private void ResetInstitutionCount(int treatmentDirectoryId)
    {
        switch (treatmentDirectoryId)
        {
            case 1:
                createPraxisModel!.NumPhysio = physiosWithExtras.Count();
                break;
            case 2:
                createPraxisModel!.NumErgo = ergosWithExtras.Count();
                break;
            case 3:
                createPraxisModel!.NumLogo = logosWithExtras.Count();
                break;
            case 4:
                createPraxisModel!.NumHeil = heilsWithExtras.Count();
                break;
            case 5:
                createPraxisModel!.NumPodo = podosWithExtras.Count();
                break;
            default:
                jsRuntime.InvokeVoidAsync("showCustomError", $"Unbekannt TreatmentDirectoryId {treatmentDirectoryId}.");
                break;
        }
    }

    private void UpdateInstitutions(int treatmentDirectoryId)
    {
        List<InstitutionInfoWithExtras> institutionInfosWithExtras = GetCurrentInstititutionWithExtrasList(treatmentDirectoryId);

        int countCurrent = treatmentDirectoryId == 1 ? createPraxisModel!.NumPhysio :
            treatmentDirectoryId == 2 ? createPraxisModel!.NumErgo :
            treatmentDirectoryId == 3 ? createPraxisModel!.NumLogo :
            treatmentDirectoryId == 4 ? createPraxisModel!.NumHeil :
            createPraxisModel!.NumPodo;

        int diff = countCurrent - institutionInfosWithExtras.Count();

        decimal price = Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.NewMaxIk);
        decimal priceMonthly = Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.ActivatedIk);

        if (diff < 0 && treatmentDirectoryId != 4 && (institutionInfosWithExtras.Where(x => x.Price != price).Any() || institutionInfosWithExtras.Where(x => x.PriceMonthly != priceMonthly).Any()))
        {
            ResetInstitutionCount(treatmentDirectoryId);
            jsRuntime.InvokeVoidAsync("showCustomError", "Der Preis für eine Institution wurde geändert, daher müssen die Institutionen im Edit-Dialog gelöscht werden.");
            return;
        }

        if (diff > 0)
        {
            for (int i = 0; i < Math.Abs(diff); i++)
            {
                AddInstitutionWithExtras(treatmentDirectoryId);
            }
        }
        else
        {
            for (int i = 0; i < Math.Abs(diff); i++)
            {
                institutionInfosWithExtras.RemoveAt(institutionInfosWithExtras.Count() - 1);
            }
        }

        switch (treatmentDirectoryId)
        {
            case 1:
                physiosWithExtras = institutionInfosWithExtras;
                break;
            case 2:
                ergosWithExtras = institutionInfosWithExtras;
                break;
            case 3:
                logosWithExtras = institutionInfosWithExtras;
                break;
            case 4:
                heilsWithExtras = institutionInfosWithExtras;
                break;
            case 5:
                podosWithExtras = institutionInfosWithExtras;
                break;
            default:
                break;
        }

        SetIsFirstNonHeilPraktikerIk();
    }

    private void AddInstitutionWithExtras(int treatmentDirectoryId)
    {
        InstitutionInfoWithExtras institutionInfoWithExtras = new InstitutionInfoWithExtras()
        {
            InstitutionInfo = new InstitutionInfo()
            {
                UUID = Guid.NewGuid(),
                PraxisID = -1,
                UserIDModified = 999999,
                DeviceIDModified = 999999,
                RegionID = -1,
                TreatmentDirectoryID = treatmentDirectoryId
            },
            Price = treatmentDirectoryId != 4 ? Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.NewMaxIk) : 0m,
            PriceMonthly = treatmentDirectoryId != 4 ? Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.ActivatedIk) : 0m
        };

        switch (treatmentDirectoryId)
        {
            case 1:
                physiosWithExtras.Add(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = physiosWithExtras;
                createPraxisModel!.NumPhysio = physiosWithExtras.Count();
                break;
            case 2:
                ergosWithExtras.Add(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = ergosWithExtras;
                createPraxisModel!.NumErgo = ergosWithExtras.Count();
                break;
            case 3:
                logosWithExtras.Add(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = logosWithExtras;
                createPraxisModel!.NumLogo = logosWithExtras.Count();
                break;
            case 4:
                heilsWithExtras.Add(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = heilsWithExtras;
                createPraxisModel!.NumHeil = heilsWithExtras.Count();
                break;
            case 5:
                podosWithExtras.Add(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = podosWithExtras;
                createPraxisModel!.NumPodo = podosWithExtras.Count();
                break;
            default:
                break;
        }

        SetIsFirstNonHeilPraktikerIk();
    }

    private void RemoveInstitutionWithExtras(int treatmentDirectoryId, InstitutionInfoWithExtras institutionInfoWithExtras)
    {
        switch (treatmentDirectoryId)
        {
            case 1:
                physiosWithExtras.Remove(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = physiosWithExtras;
                createPraxisModel!.NumPhysio = physiosWithExtras.Count();
                break;
            case 2:
                ergosWithExtras.Remove(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = ergosWithExtras;
                createPraxisModel!.NumErgo = ergosWithExtras.Count();
                break;
            case 3:
                logosWithExtras.Remove(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = logosWithExtras;
                createPraxisModel!.NumLogo = logosWithExtras.Count();
                break;
            case 4:
                heilsWithExtras.Remove(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = heilsWithExtras;
                createPraxisModel!.NumHeil = heilsWithExtras.Count();
                break;
            case 5:
                podosWithExtras.Remove(institutionInfoWithExtras);
                currentInstitutionInfosWithExtras = podosWithExtras;
                createPraxisModel!.NumPodo = podosWithExtras.Count();
                break;
            default:
                break;
        }

        SetIsFirstNonHeilPraktikerIk();
    }

    private void SetIsFirstNonHeilPraktikerIk()
    {
        bool isFirstIsSet = physiosWithExtras.Any(x => x.IsFirstNonHeilpraktiker)
                            || physiosWithExtras.Any(x => x.IsFirstNonHeilpraktiker)
                            || ergosWithExtras.Any(x => x.IsFirstNonHeilpraktiker)
                            || logosWithExtras.Any(x => x.IsFirstNonHeilpraktiker)
                            || podosWithExtras.Any(x => x.IsFirstNonHeilpraktiker);

        decimal priceNewMaxIK = Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.NewMaxIk);
        decimal priceIKMonthly = Utilities.GetBillingPrice(billingPrices!, BillingTypeEnum.ActivatedIk);

        if (!isFirstIsSet)
        {
            if (physiosWithExtras.Any())
            {
                physiosWithExtras.First().IsFirstNonHeilpraktiker = true;
                physiosWithExtras.First().Price = priceNewMaxIK;
                physiosWithExtras.First().PriceMonthly = priceIKMonthly;
            }
            else if (ergosWithExtras.Any())
            {
                ergosWithExtras.First().IsFirstNonHeilpraktiker = true;
                ergosWithExtras.First().Price = priceNewMaxIK;
                ergosWithExtras.First().PriceMonthly = priceIKMonthly;
            }
            else if (logosWithExtras.Any())
            {
                logosWithExtras.First().IsFirstNonHeilpraktiker = true;
                logosWithExtras.First().Price = priceNewMaxIK;
                logosWithExtras.First().PriceMonthly = priceIKMonthly;
            }
            else if (podosWithExtras.Any())
            {
                podosWithExtras.First().IsFirstNonHeilpraktiker = true;
                podosWithExtras.First().Price = priceNewMaxIK;
                podosWithExtras.First().PriceMonthly = priceIKMonthly;
            }
        }
    }

