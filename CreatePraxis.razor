    private async Task CreateKeeperData(bool createKeeperEntries)
    {
        if (!createKeeperEntries)
        {
            return;
        }
        
        keeperError = null;

        bool isRfhmPraxis = new [] { 3, 4, 5 }.Contains(createPraxisModel!.CashSettingInt);

        await using (var utilsAccess = new KeeperUtils(logger, new JsonConfigurationStorage("C:\\ipraxconfig\\keeperconfig.json"), KeeperUtils.CreateKeeperAuthDataFromFile("C:\\ipraxconfig\\keeperauth.json")))
        {
            await utilsAccess.Login();

            if (currentServer == CurrentServer.Live)
            {
                if (Environment.MachineName.ToLower().Contains("webserver-"))
                {
                    keeperError = await utilsAccess.AddKeyIfNotExists("ID " + createPraxisModel!.NewPraxisID, createPraxisModel!.NewPraxisID, CryptionKey!, Utils.Utils.GetCurrentServerByIP() == CurrentServer.Live, bossPW!, isRfhmPraxis);
                }
                else
                {
                    throw new Exception(@$"Expected Server: ""WebServer-"". Actual server: ""{Environment.MachineName}""");
                }
            }
            else
            {
                keeperError = await utilsAccess.AddKeyIfNotExists("TEST: ID " + (createPraxisModel!.NewPraxisID + 100000), createPraxisModel!.NewPraxisID + 100000, CryptionKey!, Utils.Utils.GetCurrentServerByIP() == CurrentServer.Live, bossPW!, isRfhmPraxis);
            }
        }

        if (keeperError is not null)
        {
            logger.LogWarning("Keeper error: \n\n " + keeperError);    
        }
        
        sendSuccessful = keeperError == null;    
    }

    private async Task UpdateKeeperTitleIfExists(bool createKeeperEntries)
    {
        if (!createKeeperEntries)
        {
            return;
        }
        
        keeperError = null;

        await using (var keeperUtils = new KeeperUtils(logger, new JsonConfigurationStorage("C:\\ipraxconfig\\keeperconfig.json"), KeeperUtils.CreateKeeperAuthDataFromFile("C:\\ipraxconfig\\keeperauth.json")))
        {
            await keeperUtils.Login();

            if (currentServer == CurrentServer.Live)
            {
                if (Environment.MachineName.ToLower().Contains("webserver-"))
                {
                    keeperError = await keeperUtils.UpdateTitleIfExists("ID " + createPraxisModel!.NewPraxisID, praxisNameKeeper!, createPraxisModel!.NewPraxisID, logger);
                }
                else
                {
                    throw new Exception(@$"Expected Server: ""WebServer-"". Actual server: ""{Environment.MachineName}""");
                }
            }
            else
            {
                praxisNameKeeper = praxisNameKeeper = "Test: " + praxisNameKeeper;
