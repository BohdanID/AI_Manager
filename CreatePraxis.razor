    private void CheckFaultyEntriesOrShowConfirmation()
    {
        if (!createPraxisContext!.Validate())
        {
            isPraxisCreationRunning = false; 
            creationButtonDisabled = false; 
            StateHasChanged();
            return;
        }
        
        if ((createPraxisModel!.NumPhysio + createPraxisModel!.NumPodo + createPraxisModel!.NumErgo + createPraxisModel!.NumLogo + createPraxisModel!.NumHeil) < 1)
        {
            jsRuntime.InvokeVoidAsync("showCustomError", "Es muss mindestens ein Insitutionskennzeichen existieren.");
            creationButtonDisabled = false;
            isPraxisCreationRunning = false;
            return;
        }
        
        if ((DateTime)createPraxisModel!.InputSignatureDateCustomer! > createPraxisModel!.StartOfContract)
        {
            errorMessage = "Der Vertragsbeginn darf nicht vor dem Datum der Kundenunterschrift (SEPA) liegen.";
            showErrorPopup = true;
            return;
        }
        
        DateTime today = DateTime.Today;
        if (createPraxisModel!.StartOfContract < new DateTime(today.Year, today.Month, 01))
        {
            errorMessage = "Der Vertragsbeginn liegt zu weit in der Vergangenheit.";
            showErrorPopup = true;
            return; 
        }
        
        creationButtonDisabled = true;
        showPraxisCreationConfirmation = true;
        StateHasChanged();
    }

    private int GetIkCountExcludingHeilpaktiker()
    {
        return createPraxisModel!.NumPhysio + createPraxisModel!.NumPodo + createPraxisModel!.NumErgo + createPraxisModel!.NumLogo;
    }

    private async void OnSubmitCreatePraxis()
    {
        if (!isPraxisCreationRunning)
        {
            isPraxisCreationRunning = true;
            praxisCreationFailure = false;
            loadingPdf = true;
            StateHasChanged();

            _oneTimeInvoiceStart = (DateTime)createPraxisModel!.StartOfContract!;
            _periodicInvoiceStart = Utilities.GetPeriodicInvoiceUploadTargetDate((DateTime)createPraxisModel!.StartOfContract, null, config);
            
            try
            {    
                SetBossPassword();
                await CreatePractice();
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
                showErrorPopup = true;
                StateHasChanged();

                return;
            }

            try
            {
                // Do not change the order of the following operations. The Errormessages depend on knowing in which order DbEntries are created
                CreateAddresses();
                CreateInstitutions(!createPraxisModel!.isIpraxCash && !isTestPraxis);
                await UpdateKeeperTitleIfExists(_createKeeperEntries);
                CreateDevices(!createPraxisModel!.isIpraxCash && !isTestPraxis);
                CreateTherapists();
                CreateUsers();

                try
                {
                    using TriggerFriendlyIpraxKundenportalDbContext iPraxKundenportalContext = iPraxKundenportalContextFactory.CreateDbContext();
                    iPraxKundenportalContext.Update(unsyncedPraxisSetting!);
                    iPraxKundenportalContext.SaveChanges();
                }
                catch (Exception ex)
                {
                    partialCreationFailure = true;
                    logger.LogError(ex, ex.Message);
                    errorMessage = "MaxDeviceCount und MaxIkCount konnten in UnsyncedPraxisSetting nicht gespeichert werden. Die Werte müssen manuell nachgetragen werden.";
                    showErrorPopup = true;
                }

                try
                {
                    /*
                    if (Startup.StaticConfig["MailSettings:SendInvitationMail"] == "1")
                    {
                        Utilities.SendIpraxDeskInvitation(createPraxisModel!.newPraxisID, createPraxisModel!.CustomerNo, navigationManager.BaseUri, iPraxKundenportalContextFactory.CreateDbContext(), logger);
                    }
                */
                }
                catch (Exception ex)
                {
                    errorMessage = "Die Einladung zum Kundenportal wurde nicht versendet.";
                    showErrorPopup = true;
                    logger.LogError(ex, ex.Message);
                }
                
                show_form = false;
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
                showErrorPopup = true;
                show_form = false;
                logger.LogError(ex, $"Failed to create Addresses, Devices, Institutions and Therapists for Praxis {createPraxisModel!.NewPraxisID}.");
            }
            finally
            {
                isPraxisCreationRunning = false;
                showPraxisCreationConfirmation = false;
                loadingPdf = false;
                StateHasChanged();
            }
        }
    }

    private void SetBossPassword()
    {
        string word_list = File.ReadAllText("Resources/words.txt");
        string[] lines = word_list.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        Random rnd = new Random();
        bossPW = lines[rnd.Next(lines.Count())];
    }

    private async Task CreatePractice()
    {
        using TriggerFriendlyIpraxDbContext iPraxDbContext = iPraxContextFactory.CreateDbContext();

        Praxis praxis = new Praxis();

        try
        {
            CryptionKey = Utilities.GenCryptionKey(16);

            int maxCustomerNo = iPraxDbContext.Praxis.AsNoTracking().Max(x => x.CustomerNo!.Value);
            praxis.CustomerNo = maxCustomerNo + 1;

            createPraxisModel!.CustomerNo = praxis.CustomerNo.Value;
            praxis.DateCreated = DateTime.Now;
            praxis.UUID = Guid.NewGuid();

            praxis.Fontsize = 10;
            praxis.Fonttype = "HelveticaNeue";
            praxis.MarginTop = 0;
            praxis.MarginBottom = 0;
            praxis.MarginLeft = 1.5;
            praxis.MarginRight = 1.5;

            string strKto = string.Empty;
            string strBLZ = string.Empty;
            string strBankname = string.Empty;

            praxis.Signature = "Zahlbar sofort ohne Abzug auf das Konto " + strKto + " BLZ " + strBLZ + " bei der " + strBankname;
            praxis.SignatureAdmonition = praxis.Signature;
            praxis.SignaturePrivate = praxis.Signature;
            praxis.SignatureSelfPay = praxis.Signature;

            praxis.PassiveTime = 0;

            praxis.SwitchOptions = 2097231;
            praxis.SwitchOptions |= 33554432;
            
            praxis.CustomerNo = createPraxisModel!.CustomerNo;
            praxis.UstID = Cryption.EncryptString("", CryptionKey!);
            praxis.IBAN = Cryption.EncryptString("", CryptionKey!);

            praxis.Name = Cryption.EncryptString(createPraxisModel!.InputPraxisname ?? "", CryptionKey!);
            praxis.OwnerName = Cryption.EncryptString(createPraxisModel!.InputFirstName + " " + createPraxisModel!.InputLastName, CryptionKey!);
            praxis.MinutesPerSegment = (int)createPraxisModel!.InputFrequency!;

            if (praxis.MinutesPerSegment != 25)
            {
                praxis.CalendarStart = new DateTime(1970, 1, 1, 6, 0, 0);
                praxis.CalendarEnd = new DateTime(1970, 1, 1, 22, 0, 0);
            }
            else
            {
                praxis.CalendarStart = new DateTime(1970, 1, 1, 6, 20, 0);
                praxis.CalendarEnd = new DateTime(1970, 1, 1, 22, 35, 0);
            }

            praxis.IsActive = 1;
            praxis.PraxisFee = 10;
            praxis.PrescriptionFee = 10;
            praxis.PercentColorSwitch = 50;
            praxis.CancelPeriod = 24;
            praxis.CancelFee = 0;
            praxis.Attributes = createPraxisModel!.isIpraxCash ? @"{ ""isIpraxCash"": ""True""}" : @"{ ""isIpraxCash"": ""False""}";
            praxis.DateModified = DateTime.Now;
            praxis.UserIDModified = 999999;
            praxis.DeviceIDModified = 999999;
            praxis.DateSync = DateTime.Now;

            iPraxDbContext.Add(praxis);
            iPraxDbContext.SaveChanges();

            createPraxisModel!.NewPraxisID = praxis.ID;
            
            await CreateKeeperData(_createKeeperEntries);

            if (!isTestPraxis)
            {
                List<CollmexRequests.CollmexBase> collmexResponse = await Utilities.CreateCollmexCustomer(praxis.CustomerNo.ToString(),
                    Utilities.GetCollmexFirmaNr(), 
                    createPraxisModel!.InputPraxisname,
                    createPraxisModel!.Department,
                    createPraxisModel!.InputFirstName, 
                    createPraxisModel!.InputLastName, 
                    createPraxisModel!.InputPlz!, 
                    createPraxisModel!.InputCity, 
                    createPraxisModel!.InputAddress, 
                    (createPraxisModel!.InputIban ?? "").Replace(" ", "").Replace("-", ""), 
                    createPraxisModel!.InputPhone, 
                    createPraxisModel!.InputMobile, 
                    createPraxisModel!.InputMail, 
                    createPraxisModel!.InputSignatureDateCustomer, 
                    bemerkung: createPraxisModel!.isIpraxCash ? "iPrax Cash" : "");
            }
        }
        catch (Exception contextIpraxEx)
        {
            praxisCreationFailure = true;
            creationButtonDisabled = false;

            logger.LogError(contextIpraxEx, "Creating new Praxis failed.  \n\n" + contextIpraxEx.Message);
            throw new Exception("Die Praxis konnte nicht erstellt werden.");
        }

        try
        {
            using TriggerFriendlyIpraxKundenportalDbContext iPraxKundenportalContext = iPraxKundenportalContextFactory.CreateDbContext();

