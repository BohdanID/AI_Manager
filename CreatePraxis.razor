            isPraxisCreationRunning = false;
            logger.LogError(iPraxKundenportalContextEx, "Creating PendingBillingChanges and UnsyncedPraxisSettings failed. \n\n" + iPraxKundenportalContextEx.Message);
            throw new Exception($"Die Praxis {createPraxisModel!.NewPraxisID} wurde angelegt, aber es wurden keine Instutitionen, Treatments, Prices, Settings, Geräte oder Spalten angelegt. Außerdem konnten die Einträge für PendingBillingChanges und UnsyncedPraxisSettings nicht erstellt werden.");
