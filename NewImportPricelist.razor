    // -----------------------------
    // Helpers (ported from old)
    // -----------------------------
    public static string[] SplitCSV(string input)
    {
        Regex csvSplit = new Regex("(?:^|,)(\"(?:[^\"]+|\"\")*\"|[^,]*)", RegexOptions.Compiled);
        List<string> list = new List<string>();
        string curr;
        foreach (Match match in csvSplit.Matches(input))
        {
            curr = match.Value;
            if (0 == curr.Length)
            {
                list.Add("");
            }
            list.Add(curr.TrimStart(',').Replace("\"", ""));
        }
        return list.ToArray();
    }

    private string SafeCell(int row, int col)
    {
        if (row < 0 || row >= pricelistRawData.Count) return "";
        if (col < 0 || col >= pricelistRawData[row].Length) return "";
        return pricelistRawData[row][col] ?? "";
    }

    private bool ContainsBundesweit(string s)
    {
        var x = (s ?? "").ToLowerInvariant();
        return x.Contains("allen bundesländern") || x.Contains("bundesweit");
    }

    private string GetInsuranceTypeKey(List<string[]> raw)
    {
        string[] textsToSearch =
        {
            SafeRaw(raw, 0, 4).ToLowerInvariant(),
            SafeRaw(raw, 0, 5).ToLowerInvariant(),
            SafeRaw(raw, 0, 6).ToLowerInvariant()
        };

        foreach (var text in textsToSearch)
        {
            foreach (var syn in synonymInsuranceType.Keys)
                if (text.Contains(syn)) return synonymInsuranceType[syn];
        }
        return "";
    }

    private string SafeRaw(List<string[]> raw, int r, int c)
    {
        if (r < 0 || r >= raw.Count) return "";
        if (c < 0 || c >= raw[r].Length) return "";
        return raw[r][c] ?? "";
    }

    private List<string> GetNewTreatmentsList(List<string[]> raw)
    {
        var newTreatments = new List<string>();
        for (int i = 2; i < raw.Count; i++)
        {
            var row = raw[i];
            if (row.Length != 6) continue;
            if (!allTreatments.Contains(row[0]))
                newTreatments.Add(row[0] + " " + row[3]);
        }
        return newTreatments;
    }

    private int GetTreatmentIDByPosNr(string posNr)
    {
        foreach (var kv in treatmentsRestricted)
            if (string.Equals(kv.Value.PosNr, posNr, StringComparison.OrdinalIgnoreCase))
                return kv.Key;
        return -1;
    }

    private int GetDoubleTreatmentIDByPosNr(string posNr)
    {
        foreach (var kv in doubleTreatments)
            if (string.Equals(kv.Value.PosNr, posNr, StringComparison.OrdinalIgnoreCase))
                return kv.Key;
        return -1;
    }

    private bool TryParsePrice(string raw, out decimal price)
    {
        // old: decimal.Parse(value.Replace(",", "."), InvariantCulture)
        var s = (raw ?? "").Trim().Replace(",", "."); // allow both
        return decimal.TryParse(s, NumberStyles.Any, CultureInfo.InvariantCulture, out price);
    }

    private IEnumerable<AssociationRow> GetAssociationsForCurrentDirectory()
        => allAssociations.Where(x => x.TreatmentDirectoryID == treatmentDirectoryID).OrderBy(x => x.Description);

    private List<KeyValuePair<int, string>> GetUnionsForInsuranceType()
    {
        var name = allInsuranceTypes.TryGetValue(selectedInsuranceTypeId, out var n) ? n : "GKV";
        return allInsuranceTypesUnions.TryGetValue(name, out var list) ? list : new();
    }

    private string GetRegionName(int id) => allRegions.TryGetValue(id, out var n) ? n : id.ToString();

    private string GetUnionName(int id)
        => allInsuranceUnions.TryGetValue(id, out var n) ? n : (unionAbbreviations.TryGetValue(id, out var ab) ? ab : id.ToString());

    private string GetAssociationName(int id)
        => allAssociations.FirstOrDefault(x => x.ID == id)?.Description ?? id.ToString();

    private string ResolveConnectionString()
    {
        // 1) Try Utilities.GetIpraxDbConnectionString() if it exists
        try
        {
            var m = typeof(Utilities).GetMethod("GetIpraxDbConnectionString", BindingFlags.Public | BindingFlags.Static);
            if (m is not null)
            {
                var v = m.Invoke(null, null)?.ToString();
                if (!string.IsNullOrWhiteSpace(v)) return v!;
            }
        }
        catch { /* ignore */ }

        // 2) Try common config keys
        foreach (var key in new[] { "iPraxDb", "IpraxDb", "DefaultConnection" })
        {
            var v = config.GetConnectionString(key);
            if (!string.IsNullOrWhiteSpace(v)) return v!;
        }

        throw new InvalidOperationException("Keine ConnectionString gefunden. Bitte appsettings ConnectionStrings prüfen (z.B. 'DefaultConnection').");
    }
}